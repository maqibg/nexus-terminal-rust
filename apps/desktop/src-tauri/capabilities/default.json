{
  "identifier": "default",
  "description": "Default capability for Nexus Terminal",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:event:default",
    "log:default",
    "dialog:default",
    "fs:default",
    "opener:default",
    "shell:default"
  ]
}
